# API keys — copy this file to .env and fill in your values.
# Only the providers you actually configure in pipeline.yaml are required.

# Anthropic-family (Claude API direct, optional — Claude Code CLI is the
# default agent transport and uses your local OAuth login)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI / OpenRouter — main LLM providers used by the pipeline
OPENAI_API_KEY=sk-your-key-here
OPENROUTER_API_KEY=sk-or-your-key-here

# Other LLM providers (optional — enable if pipeline.yaml references them)
GEMINI_API_KEY=your-key-here

# Tooling
SERPER_API_KEY=your-key-here          # web search ability
HF_TOKEN=hf_your-token-here           # HuggingFace dataset/model access
GH_TOKEN=ghp_your-token-here          # paper-repo deploy step
LEANEXPLORE_API_KEY=your-key-here     # Lean theorem-proving ability (optional)

# OpenAlex polite-pool identifier (used by the get_papers step)
RESEARCHER_EMAIL=your-email@example.com
