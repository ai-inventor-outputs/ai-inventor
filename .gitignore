CACHED
=
.claude/skills/aii-owid-datasets/_setup/table_metadata.json

# Large test/temp directories
temp-dataset-executor-test/
.bak/

# MCP config (contains API keys and machine-specific paths)
.mcp.json

# Claude credentials (OAuth tokens — never commit)
claude-credentials.json

# Private overrides — sit next to their public ``<thing>.yaml``
# counterpart and are deep-merged on top at load time.
# Examples: aii_config/pipeline/harness/llm_backend.private.yaml,
#           aii_config/server/server.private.yaml
*.private.yaml

# Gitleaks config — project-specific deny-list of personal emails,
# RunPod ids, OTel endpoint. Excluded from the public clone so the
# rules themselves don't leak the strings.
aii_public/gitleaks.toml

# Datasets (download from HuggingFace as needed)
datasets/

# .claude skill artifacts (large files - download/generate separately)
.claude/skills/**/scripts/.venv/
.claude/skills/**/temp/
.claude/skills/**/scripts/__pycache__/
.claude/skills/aii-owid-datasets/_index/
.claude/skills/aii-owid-datasets/_setup/
.claude/skills/archived/
temp2/
**/temp2/
**/checkpoints/
**/checkpoint_*.json
**/table_metadata.json
**/table_metadata_filtered.json

# Node modules (should never be committed)
**/node_modules/

# Invention KG runtime data artifacts (regenerated by pipeline)
aii_pipeline/src/aii_pipeline/steps/_1_seed_hypo/invention_kg/data/

# my_papers large files (keep code/ and papers/)
resources/my_papers/skrlj-invention-ablation/experiments/data/original_out/

# Dev/debug screenshots dropped in repo root by Playwright/MCP iterations
/v[0-9]*-*.png
/trace-*.png
/main-sb.png
.playwright-mcp/

# Playwright trace YAML dumps at repo root (Playwright/MCP iterations).
# All ``*.yml`` files in repo root EXCEPT ``lefthook.yml`` are testing
# artifacts that should never be committed; typos otherwise flags
# random run-ID substrings ("Ba" in "XP06cBa9022") as misspellings.
/*.yml
!/lefthook.yml

# Claude playwright skill scratch files
.claude/skills/playwright/.temp-execution-*.js

# AI invention runtime outputs that occasionally land in aii_frontend/
aii_frontend/ai-invention-*/

# Claude agent worktrees (created by Agent tool with isolation: "worktree")
.claude/worktrees/
.claude/scheduled_tasks.lock
aii_frontend/test-results/

# Embedded eval repos (kept locally, not in our git)
aii_eval/chemcot/
aii_eval/sgi-bench/
aii_eval/asta-bench/

# SGI eval scripts occasionally write logs to repo root (from cwd at
# invocation time) — same content as aii_eval/sgi-bench/evaluation/
# task_*_*/, just at the wrong path. Generated artefacts, not source.
/task_[0-9]*_*/

# Session-scratch handoff docs at repo root — regenerated each session
# from working memory; not part of the project history.
/paper_writing_continue.md
/PHASE[0-9]*_*.md

# Per-sample agent working dirs (cwd for both AII and Claude Agent runs)
aii_eval/*/agent_dirs/
